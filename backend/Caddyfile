# Flo POS - Local Development Caddyfile
# Backend API Server

# API Server - api.flopos.local
http://api.flopos.local:8080 {
    # Root directory
    root * /home/ubuntu/flopos-backend/public

    # Enable gzip compression
    encode gzip

    # PHP-FPM configuration
    php_fastcgi unix//run/php/php8.4-fpm.sock {
        env APP_ENV local
        env APP_DEBUG true
    }

    # Laravel-style URL rewriting
    @notStatic {
        not file
        not path /index.php
    }
    rewrite @notStatic /index.php

    # Security headers
    header {
        # CORS for local development
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
        Access-Control-Max-Age 3600

        # Security
        X-Frame-Options SAMEORIGIN
        X-Content-Type-Options nosniff
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Handle OPTIONS requests for CORS
    @options {
        method OPTIONS
    }
    respond @options 204

    # File server for static assets
    file_server

    # Logging
    log {
        output file /var/log/caddy/flopos-api.log
        format json
        level INFO
    }
}

# Main Website - flopos.local (for Next.js frontend - will be added later)
http://flopos.local:3000 {
    reverse_proxy localhost:3001

    log {
        output file /var/log/caddy/flopos-frontend.log
        format json
        level INFO
    }
}

# Health check endpoint
http://localhost:2019 {
    respond /health 200 {
        body "Caddy is running"
    }
}
